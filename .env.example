# URL pubblico del sistema — usato per generare link preventivi in WhatsApp e email
# In produzione: https://preventivi.ischiastars.it
# In sviluppo locale: http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# Supabase — lascia vuoto per usare l'ambiente locale con dati iniziali
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — usata solo lato server (API routes), non esposta al client
SUPABASE_SERVICE_ROLE_KEY=

# Numero WhatsApp IschiaStars (formato internazionale, solo cifre)
# Usato nella pagina cliente per il bottone "Scrivici su WhatsApp"
# Il bottone backoffice "Invia su WhatsApp" usa invece il numero del cliente
NEXT_PUBLIC_ISCHIASTARS_WHATSAPP=393717590017

# Protezione minima opzionale per le POST admin
ADMIN_API_KEY=

# Chiave segreta per chiamare /api/cron/poll-email da un cron esterno
CRON_SECRET=

# Brevo — email transazionali (preventivo al cliente e conferma interna)
# Imposta BREVO_ENABLED=true per abilitare l'invio. Se false o assente, nessuna email viene inviata.
# Il mittente info@ischiastars.it deve essere verificato su Brevo e il dominio ischiastars.it autenticato.
# In locale usa .env.local; in produzione configura le variabili nella dashboard Vercel.
# Non usare mai NEXT_PUBLIC_BREVO_API_KEY — la chiave è solo server-side.
BREVO_ENABLED=false
BREVO_API_KEY=
BREVO_FROM_EMAIL=info@ischiastars.it
BREVO_FROM_NAME=IschiaStars
BREVO_INTERNAL_NOTIFY_EMAIL=info@ischiastars.it

# WordPress ischiastars.it — credenziali per import hotel autenticato (ACF fields)
# Genera una Application Password in WP Admin → Utenti → Profilo → Password Applicazioni
# Con queste variabili l'import recupera: descrizione, servizi, policy (da ACF)
# Senza variabili: import funziona comunque (nome, zona, immagine da API pubblica)
ISCHIASTARS_WP_USER=
ISCHIASTARS_WP_APP_PASSWORD=

# Import email in arrivo — IMAP Aruba (info@ischiastars.it)
# Le email in arrivo con richieste preventivo vengono lette direttamente via IMAP.
# Brevo resta usato solo per l'INVIO di email in uscita.
# In produzione: configura queste variabili su Vercel → Settings → Environment Variables.
MAIL_INBOX_PROVIDER=imap
MAIL_INBOX_HOST=imap.ischiastars.it
MAIL_INBOX_PORT=993
MAIL_INBOX_SECURE=true
MAIL_INBOX_USER=info@ischiastars.it
MAIL_INBOX_PASSWORD=
MAIL_INBOX_FROM=info@ischiastars.it
MAIL_INBOX_FOLDER=INBOX
MAIL_INBOX_LOOKBACK_DAYS=7

# Gmail — DEPRECATO: non più usato.
# L'import email avviene ora via IMAP Aruba (vedi MAIL_INBOX_* sopra).
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_EMAIL=
# IP interni/test da non conteggiare nel tracking pubblico (separati da virgola)
TRACKING_EXCLUDED_IPS=93.148.93.103
